  "weekMeta": {
    "week1": {
      "title": "Robot Photo Challenge",
      "task": "Join the #ai-unlock10x channel, post a photo of your favorite robot, and throw up a 🤙. That's it — introduce yourself to AI enablement.",
      "deadline": "Wednesday EOD",
      "maxPoints": 60,
      "latePolicy": "50% of base score, no speed bonus or BIC eligible"
    },
    "week2": {
      "title": "From Chat to CoWork",
      "task": "Audit your software tools, set up Connectors in CoWork, identify 3 workflow candidates for Skills/Schedule, and build one scheduled workflow with screenshots posted to #ai-unlock10x.",
      "deadline": "Friday 12pm ET",
      "maxPoints": 60,
      "latePolicy": "50% of base score, no speed bonus or BIC eligible",
      "contentUrl": "week2.html"
    },
    "week3": {
      "title": "Claude in Chrome",
      "task": "Extend your tool audit, identify 3 action workflows using Claude in Chrome, build one, and record a screen capture of it running end to end.",
      "deadline": "Friday 12pm ET",
      "maxPoints": 60,
      "latePolicy": "50% of base score, no speed bonus or BIC eligible",
      "contentUrl": "week3.html"
    },
    "week4": {
      "title": "Borrow and Build",
      "task": "Get on X, find 3 function-specific inspiration examples from the AI conversation, document the inspiration and translation for each, build your strongest one, and post everything in #ai-unlock10x.",
      "deadline": "Friday 12pm ET",
      "maxPoints": 60,
      "latePolicy": "50% of base score, no speed bonus or BIC eligible",
      "contentUrl": "week4.html"
    }
  },
